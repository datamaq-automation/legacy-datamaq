# Variables de entorno para datamaq-www
# Archivo canonico de referencia.
# Recomendado:
# - Desarrollo local: crear `.env.local` (no versionado) a partir de esta plantilla.
# - E2E del repo: usar `.env.e2e`.
# La configuracion publica del sitio vive en `src/infrastructure/content/content.ts`.

# URL base del backend.
# El frontend agrega internamente:
# - /api/contact para formulario de contacto
# - /api/mail para formulario de "Enviar mail"
# Ejemplo local: http://127.0.0.1:4173
# Ejemplo produccion: https://api.datamaq.com.ar
VITE_BACKEND_BASE_URL=

# Activacion de formularios (render condicional).
# Valores permitidos: true | false
VITE_IS_CONTACT_FORM_ACTIVE=true
VITE_IS_EMAIL_FORM_ACTIVE=true
