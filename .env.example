# Variables de entorno para datamaq-www
# Copiï¿½ este archivo a `.env` y completï¿½ los valores reales segï¿½n cada entorno.
# La configuraciï¿½n pï¿½blica del sitio vive en `src/infrastructure/content/content.ts`.

# Endpoint HTTPS que recibe el formulario de contacto (backend recomendado)
# Ejemplo: https://<BACKEND_HOST>/v1/contact
VITE_CONTACT_API_URL=

# Email de contacto visible (usa fallback si no se define)
VITE_CONTACT_EMAIL=

# Header de verificacion de origen requerido por el backend
VITE_ORIGIN_VERIFY_SECRET=
