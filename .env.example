# Variables de entorno para datamaq-www
# Archivo canonico de referencia.
# Recomendado:
# - Desarrollo local: crear `.env.local` (no versionado) a partir de esta plantilla.
# - E2E del repo: usar `.env.e2e`.
# La configuracion publica del sitio vive en `src/infrastructure/content/content.ts`.

# Endpoint de backend para formulario de contacto (lead).
# Ejemplo local: http://127.0.0.1:4173/api/contact
# Ejemplo produccion: https://api.datamaq.com.ar/contact
VITE_CONTACT_API_URL=

# Endpoint de backend para formulario "Enviar mail" (consulta tipo email).
# Ejemplo local: http://127.0.0.1:4173/api/mail
# Ejemplo produccion: https://api.datamaq.com.ar/mail
VITE_MAIL_API_URL=

# Fallback transitorio para compatibilidad.
# Preferir VITE_CONTACT_API_URL para nuevas configuraciones.
VITE_INQUIRY_API_URL=

# Nivel de logging cliente para formularios/contacto: debug | info | warn | error
# Recomendado local: info (menos ruido). Usar debug solo para diagnostico puntual.
VITE_CLIENT_LOG_LEVEL=info
