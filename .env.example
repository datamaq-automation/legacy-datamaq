# Variables de entorno para datamaq-www
# Copia este archivo a `.env` y completa los valores segun cada entorno.
# La configuracion publica del sitio vive en `src/infrastructure/content/content.ts`.

# Endpoint HTTPS de Chatwoot Public API para crear contacto.
# Debe terminar en /public/api/v1/inboxes/{inbox_identifier}/contacts
# Ejemplo: https://chatwoot.datamaq.com.ar/public/api/v1/inboxes/<INBOX_IDENTIFIER>/contacts
# Nota: si activas secure mode (identifier_hash/HMAC), vas a necesitar un firmador backend.
VITE_CONTACT_API_URL=

# Email de contacto visible (usa fallback si no se define)
VITE_CONTACT_EMAIL=
