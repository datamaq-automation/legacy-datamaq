# Variables de entorno para profebustos-www
# Copiá este archivo a `.env` y completá los valores reales según cada entorno.

# Número de WhatsApp en formato internacional sin signos (+ ni espacios)
VITE_WHATSAPP_NUMBER=5491100000000

# Mensaje prellenado para el CTA de WhatsApp (opcional)
VITE_WHATSAPP_PRESET_MESSAGE=Vengo de la página web, quiero más información.

# URL del chat conversacional (debe exponer HTTPS)

# IDs de analítica (opcional)
VITE_CLARITY_PROJECT_ID=
VITE_GA4_ID=G-XXXXXXXXXX

# Correo destino para el formulario de contacto
VITE_CONTACT_EMAIL=contacto@profebustos.com.ar

# Endpoint HTTPS de la API que recibe los formularios/contactos de WhatsApp
VITE_CONTACT_API_URL=https://api.profebustos.com.ar/contact
